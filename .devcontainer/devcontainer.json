// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/miniconda
{
    "name": "RNAvigate",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    // Install the project in editable mode after the workspace is mounted.
    // All dependencies are already baked into /opt/venv by the Dockerfile,
    // so this step is fast (no network round-trip needed).
    "postCreateCommand": "uv sync --extra dev --extra docs",
    // Configure tool-specific properties.
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.isort",
                "njpwerner.autodocstring",
                "aaron-bond.better-comments",
                "ms-python.black-formatter",
                "ms-toolsai.jupyter",
                "ms-toolsai.vscode-jupyter-cell-tags",
                "ms-toolsai.jupyter-renderers",
                "shd101wyy.markdown-preview-enhanced",
                "ms-python.vscode-pylance",
                "ms-python.pylint",
                "ms-python.python",
                "RomanPeshkov.vscode-text-tables",
                "vscode-icons-team.vscode-icons"
            ],
            "settings": {
                "[python]": {
                    "editor.defaultFormatter": "ms-python.black-formatter",
                    "editor.formatOnSave": true
                },
                "pylint.cwd": "${workspaceFolder}",
                "files.eol": "\n",
                // Point VS Code and the Jupyter extension at the pre-built venv.
                "python.defaultInterpreterPath": "/opt/venv/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}"
            }
        }
    }
    // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
    // "remoteUser": "root"
}
